# VISION - Backend Environment Variables Template

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/vision-exam

# Security - IMPORTANT: Change this in production
JWT_SECRET=vision_super_secret_key_change_me_12345

# Redis Configuration (Optional for production, required for live monitoring grid)
REDIS_URL=redis://localhost:6379

# External APIs
# Judge0 API for coding question execution (Default is public demo)
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=

# Client Configuration (CORS)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
