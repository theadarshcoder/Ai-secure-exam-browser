{
  "name": "vision-secure-browser",
  "version": "1.0.0",
  "description": "Secure Browser for VISION Exam Platform",
  "author": "Vision Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0"
  },
  "build": {
    "appId": "com.vision.secure",
    "productName": "VISION_Secure_Browser",
    "win": {
      "target": "nsis",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
